# ═══════════════════════════════════════════════════════════════
#  Ritual Sovereign Agent — Environment Configuration
# ═══════════════════════════════════════════════════════════════
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
# ═══════════════════════════════════════════════════════════════


# ── Blockchain ─────────────────────────────────────────────────
# Your EOA private key (0x-prefixed hex string)
# WARNING: NEVER commit this to git or share it publicly
PRIVATE_KEY=0x_your_private_key_here

# Ritual Chain RPC endpoint
RPC_URL=https://rpc.ritualfoundation.org


# ── LLM Provider ──────────────────────────────────────────────
# Options: native | openrouter | openai | anthropic | gemini
#
# native = Ritual Native LLM (no API key needed, runs on-chain)
#   Default model: zai-org/GLM-4.7-FP8
#   Also available: meta-llama/Llama-3.3-70B-Instruct, Qwen/Qwen3-32B, deepseek-ai/DeepSeek-R1
#
# openrouter | openai | anthropic | gemini = External provider (requires API key)
#
LLM_PROVIDER=native

# Only needed if LLM_PROVIDER != native:
# OPENROUTER_API_KEY=sk-or-v1-your-key-here
# OPENAI_API_KEY=sk-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# GEMINI_API_KEY=your-key-here


# ── Model ─────────────────────────────────────────────────────
# Model identifier
# Native: zai-org/GLM-4.7-FP8 (default), meta-llama/Llama-3.3-70B-Instruct, Qwen/Qwen3-32B, deepseek-ai/DeepSeek-R1
# OpenRouter: google/gemini-2.5-flash, anthropic/claude-sonnet-4-5-20250929, ...
# OpenAI: gpt-4o-mini, gpt-4o, ...
# Anthropic: claude-sonnet-4-5-20250929, claude-haiku-4-5-20250929, ...
# Gemini: gemini-2.5-flash, gemini-2.5-pro, ...
MODEL=zai-org/GLM-4.7-FP8


# ── HuggingFace (conversation history + artifacts) ────────────
# Get token: https://huggingface.co/settings/tokens (REQUIRES write access)
# Create dataset: https://huggingface.co/new-dataset (format: username/repo-name)
HF_TOKEN=hf_your_token_here
HF_REPO_ID=yourname/agent-data


# ── Agent Prompt ──────────────────────────────────────────────
# Custom prompt for your agent. If empty, uses templates/default-prompt.txt
# Keep it concise — the executor sees this every heartbeat
AGENT_PROMPT=


# ── Deployment Config ─────────────────────────────────────────
# Unique salt for deterministic harness address (change for each agent)
SALT=my-sovereign-agent

# Agent runtime type: 6 = ZeroClaw (recommended)
CLI_TYPE=6

# Blocks between executions (~0.35s per block)
# 2000 = ~12 min, 5000 = ~29 min, 10000 = ~58 min
FREQUENCY=5000

# Calls per rolling window (affects window duration)
WINDOW_NUM_CALLS=5

# When to schedule next window (basis points, 5000 = 50%)
ROLLOVER_THRESHOLD_BPS=5000

# RITUAL to deposit into harness RitualWallet
FUND_AMOUNT=0.1

# Lock duration in blocks (350ms per block)
# 61714 = ~6h, 123429 = ~12h, 246857 = ~1d, 741000 = ~3d, 1728000 = ~7d
LOCK_DURATION=1728000
